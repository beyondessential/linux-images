#!/bin/bash
LOG=/var/log/bes-installer.log

/usr/local/bin/bes-installer --log "$LOG"
RC=$?

if [ "$RC" -ne 0 ]; then
    printf '\033[?1049l'
    echo ""
    echo "=========================================="
    echo " BES Installer exited with error (rc=$RC)"
    echo "=========================================="
    echo ""
    if [ -f "$LOG" ]; then
        echo "Log output:"
        cat "$LOG"
        echo ""
    fi
    echo "Press Enter to retry, or Ctrl-Alt-F1 for a shell."
    read -r
fi

exit "$RC"

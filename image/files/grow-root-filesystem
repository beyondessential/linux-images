#!/bin/bash
# r[depends image.growth.service+3]: Grow the root partition and filesystem at boot.
#
# On first boot (or any boot where the disk is larger than the partition table
# accounts for), this script expands the root partition and filesystem to fill
# all available space.
#
# Order of operations:
#   1. Move the GPT secondary header to the end of the disk.
#   2. Run growpart on the root partition (partition 3).
#   3. If LUKS is active, resize the LUKS container.
#   4. Resize the BTRFS filesystem to fill the partition.
set -euo pipefail

DISK=/dev/$(lsblk -ndo PKNAME /dev/disk/by-partlabel/root)
PART_NUM=$(lsblk -ndo KNAME /dev/disk/by-partlabel/root | grep -o '[0-9]*$')

# Step 1: Move GPT secondary header
sgdisk --move-second-header "$DISK"
partprobe "$DISK" || true

# Step 2: Grow the partition
GROW_RC=0
growpart --free-percent=1 "$DISK" "$PART_NUM" || GROW_RC=$?
if [ "$GROW_RC" -eq 0 ]; then
    echo "Partition grown successfully"
elif [ "$GROW_RC" -eq 1 ]; then
    echo "No change needed"
    exit 0
else
    echo "growpart failed with exit code $GROW_RC"
    exit "$GROW_RC"
fi

set -x
partprobe "$DISK" || true

# Step 3: Resize LUKS (if active)
if [ -e /dev/mapper/root ]; then
    LUKS_DEV=/dev/disk/by-partlabel/root
    # cryptsetup resize re-derives the master key from a passphrase
    # rather than reusing the open mapping's key. Build-time images ship
    # with the placeholder empty passphrase in slot 0 (per
    # r[image.variant.types]); once that's rotated, we can't proceed
    # without the user's key. Probe first so we exit cleanly instead of
    # leaving a failed unit on every subsequent boot.
    if printf '' | cryptsetup open --test-passphrase --key-file=- "$LUKS_DEV"; then
        printf '' | cryptsetup resize --key-file=- root
    else
        echo "LUKS slot 0 placeholder passphrase has been rotated;"
        echo "skipping resize. To finish manually, run:"
        echo "  cryptsetup resize root   # with your key"
        echo "  btrfs filesystem resize max /"
        exit 0
    fi
fi

# Step 4: Resize BTRFS
btrfs filesystem resize max /
fdisk -l "$DISK"

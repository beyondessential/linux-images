#!/bin/bash
# r[image.tailscale.firstboot-auth]
#
# Authenticate to Tailscale using a pre-staged auth key. Two locations are
# checked, in priority order:
#
#   /etc/bes/tailscale-authkey       — written by the installer onto the
#                                      root filesystem.
#   /boot/firmware/tailscale-authkey — operator drop-in on the pi variant's
#                                      firmware FAT partition; lets an
#                                      operator pre-stage the key from a
#                                      workstation before the device's first
#                                      boot, so it joins the tailnet without
#                                      console or LAN access.
#
# This script is invoked by bes-tailscale-firstboot-auth.service, which has
# triggering ConditionPathExists= entries for both paths. If tailscale is
# already authenticated, the script exits cleanly and does not consume or
# modify any key file. On success the consumed key file is deleted and the
# SSH UFW rule is restricted to LAN ranges and the tailscale0 interface
# (the same firewall tightening that ts-up performs).
set -euo pipefail

KEY_PATHS=(
    /etc/bes/tailscale-authkey
    /boot/firmware/tailscale-authkey
)

if tailscale status > /dev/null 2>&1; then
    echo "Tailscale is already authenticated; nothing to do."
    exit 0
fi

KEY_FILE=""
for candidate in "${KEY_PATHS[@]}"; do
    if [ -s "$candidate" ]; then
        KEY_FILE="$candidate"
        break
    fi
done

if [ -z "$KEY_FILE" ]; then
    echo "ERROR: no non-empty auth-key file found at any of: ${KEY_PATHS[*]}" >&2
    exit 1
fi

AUTH_KEY="$(head -n1 "$KEY_FILE" | tr -d '[:space:]')"
if [ -z "$AUTH_KEY" ]; then
    echo "ERROR: $KEY_FILE is empty or contains only whitespace" >&2
    exit 1
fi

echo "Authenticating to Tailscale (key from $KEY_FILE)..."
if ! tailscale up --auth-key="$AUTH_KEY" --ssh; then
    echo "ERROR: tailscale up failed" >&2
    exit 1
fi

echo "Tailscale authenticated successfully."

rm -f "$KEY_FILE"

echo "Restricting SSH access to LAN and Tailscale..."

ufw delete allow 22/tcp 2>/dev/null || true

ufw allow from 10.0.0.0/8 to any port 22 proto tcp comment 'SSH from LAN'
ufw allow from 172.16.0.0/12 to any port 22 proto tcp comment 'SSH from LAN'
ufw allow from 192.168.0.0/16 to any port 22 proto tcp comment 'SSH from LAN'
ufw allow from fc00::/7 to any port 22 proto tcp comment 'SSH from LAN (IPv6)'
ufw allow in on tailscale0 to any port 22 proto tcp comment 'SSH from Tailscale'

ufw reload

echo "SSH access restricted to LAN and Tailscale networks."

#!/bin/bash
# r[image.tpm.enrollment]: Bind LUKS volume to TPM2 PCR 7, remove empty
# passphrase slot, update crypttab, and regenerate initramfs.
set -euxo pipefail

# Enroll TPM2 — use the empty keyfile to unlock, then bind to PCR 7
password_slot=$(systemd-cryptenroll /dev/disk/by-partlabel/root | grep password | awk '{print $1}')
systemd-cryptenroll \
    --wipe-slot="$password_slot" \
    --tpm2-device=auto \
    --tpm2-pcrs=7 \
    /dev/disk/by-partlabel/root \
    --unlock-key-file=/etc/luks/empty-keyfile

# Update crypttab: switch from keyfile to TPM2
sed -i 's|/etc/luks/empty-keyfile|tpm2-device=auto|' /etc/crypttab
sed -i 's|try-empty-password=true|tpm2-device=auto|' /etc/crypttab
sed -i 's|force,||' /etc/crypttab

# Mark enrollment as complete so the service doesn't run again
touch /etc/luks/tpm-enrolled

# Disable ourselves
systemctl disable setup-tpm-unlock.service

# Regenerate initramfs to include the new crypttab
dracut -f
